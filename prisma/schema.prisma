generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id                   String        @id @default(cuid())
  name                 String
  slug                 String        @unique
  logoUrl              String?
  address              String?
  subscriptionStatus   String        @default("active")
  phone                String?
  about                String?
  coverPhotoUrl        String?
  googleMapsUrl        String?
  bookingUrl           String?
  openingHours         Json?
  defaultReminderWeeks Int           @default(6)
  defaultCutTime       Int           @default(20)
  allowBarberReminders Boolean           @default(false)
  shopType             String?       @default("uk_general")
  createdAt            DateTime      @default(now())
  barbers              Barber[]
  customers            Customer[]
  visits               Visit[]
  smsLogs              SmsLog[]
  photos               ShopPhoto[]
  services             ShopService[]
  feedbacks            Feedback[]
  styles               ShopStyle[]
  appointments         Appointment[]
  walkIns              WalkIn[]
}

model ShopStyle {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  category  String // "fade"|"taper"|"classic"|"natural"|"beard"
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  imageUrl  String?
  createdAt DateTime @default(now())

  @@unique([shopId, name])
  @@index([shopId, category])
  @@index([shopId, active])
}

model Barber {
  id               String           @id @default(cuid())
  shopId           String
  shop             Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name             String
  email            String
  passwordHash     String
  role             String           @default("barber")
  isActive         Boolean          @default(true)
  bio              String?
  photoUrl         String?
  workingHours     Json?
  acceptsBookings  Boolean          @default(true)
  isBusy           Boolean          @default(false)
  resetToken       String?          @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime         @default(now())
  visits           Visit[]
  feedbackTickets  FeedbackTicket[]
  primaryCustomers Customer[]       @relation("PrimaryBarber")
  appointments     Appointment[]

  @@unique([email, shopId])
  @@index([shopId])
}

model Customer {
  id                     String        @id @default(cuid())
  shopId                 String
  shop                   Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  phone                  String
  name                   String?
  accessCode             String?       @unique
  smsOptIn               String        @default("not_asked")
  lastVisitAt            DateTime?
  preferredReminderWeeks Int?
  primaryBarberId        String?
  primaryBarber          Barber?       @relation("PrimaryBarber", fields: [primaryBarberId], references: [id], onDelete: SetNull)
  otpCode                String?
  otpExpiry              DateTime?
  createdAt              DateTime      @default(now())
  visits                 Visit[]
  smsLogs                SmsLog[]
  feedbacks              Feedback[]
  checkIns               CheckIn[]
  appointments           Appointment[]
  walkIns                WalkIn[]

  @@unique([phone, shopId])
  @@index([shopId, phone])
  @@index([shopId, name])
}

model Visit {
  id                  String       @id @default(cuid())
  shopId              String
  shop                Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId          String
  customer            Customer     @relation(fields: [customerId], references: [id])
  barberId            String
  barber              Barber       @relation(fields: [barberId], references: [id])
  visitedAt           DateTime     @default(now())
  notes               String?
  cutDetails          Json?
  recommendation      String?
  cutRating           String?
  reminderScheduledAt DateTime?
  reminderSentAt      DateTime?
  photos              VisitPhoto[]
  feedbacks           Feedback[]
  createdAt           DateTime     @default(now())

  @@index([customerId])
  @@index([shopId, visitedAt])
}

model VisitPhoto {
  id        String   @id @default(cuid())
  visitId   String
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  url       String
  angle     String
  createdAt DateTime @default(now())
}

model SmsLog {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  message    String
  twilioSid  String?
  status     String   @default("sent")
  sentAt     DateTime @default(now())
}

model ShopPhoto {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([shopId])
}

model ShopService {
  id           String        @id @default(cuid())
  shopId       String
  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name         String
  price        Decimal?      @db.Decimal(10, 2)
  duration     Int?
  description  String?
  sortOrder    Int           @default(0)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  appointments Appointment[]

  @@index([shopId])
}

model Feedback {
  id         String   @id @default(cuid())
  shopId     String
  customerId String
  visitId    String
  rating     String // "positive"|"neutral"|"negative"
  issue      String?
  sourceType String // "in_shop"|"web"
  createdAt  DateTime @default(now())

  shop     Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  visit    Visit           @relation(fields: [visitId], references: [id], onDelete: Cascade)
  ticket   FeedbackTicket?

  @@index([shopId, createdAt])
  @@index([customerId, createdAt])
  @@index([visitId])
}

model FeedbackTicket {
  id               String    @id @default(cuid())
  feedbackId       String    @unique
  status           String    @default("unresolved") // "unresolved"|"in_progress"|"resolved"
  resolution       String? // "same_barber_fix"|"different_barber"|"book_return"|"owner_contact"|"log_only"
  assignedBarberId String?
  preferredDate    DateTime?
  notes            String?
  followUpDate     DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  barber   Barber?  @relation(fields: [assignedBarberId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

model CheckIn {
  id               String    @id @default(cuid())
  customerId       String
  shopId           String?
  referenceVisitId String?
  styleId          String?
  qrToken          String    @unique @default(uuid())
  expiresAt        DateTime
  scannedAt        DateTime?
  createdAt        DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Appointment {
  id             String    @id @default(cuid())
  shopId         String
  customerId     String
  barberId       String?
  serviceId      String?
  scheduledAt    DateTime
  duration       Int // minutes
  status         String // "booked"|"in_progress"|"completed"|"cancelled"
  notes          String?
  reminderSentAt DateTime?
  createdAt      DateTime  @default(now())

  shop     Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  barber   Barber?      @relation(fields: [barberId], references: [id], onDelete: SetNull)
  service  ShopService? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([shopId, scheduledAt])
  @@index([customerId, scheduledAt])
  @@index([barberId, scheduledAt])
}

model WalkIn {
  id             String    @id @default(cuid())
  shopId         String
  shop           Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  note           String?
  preferredStyle String?   // client-selected styles from arrival screen, JSON array
  status         String    @default("waiting") // "waiting"|"in_progress"|"done"|"no_show"
  arrivedAt      DateTime  @default(now())
  startedAt      DateTime?
  doneAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([shopId, arrivedAt])
  @@index([shopId, status])
}

model DemoLead {
  id        String   @id @default(cuid())
  name      String
  shopName  String
  phone     String
  email     String
  createdAt DateTime @default(now())
}
