generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id                   String        @id @default(cuid())
  name                 String
  slug                 String        @unique
  logoUrl              String?
  address              String?
  subscriptionStatus   String        @default("active")
  createdAt            DateTime      @default(now())
  phone                String?
  about                String?
  coverPhotoUrl        String?
  googleMapsUrl        String?
  bookingUrl           String?
  openingHours         Json?
  defaultReminderWeeks Int           @default(6)
  shopType             String?       @default("uk_general")
  allowBarberReminders Boolean       @default(false)
  defaultCutTime       Int           @default(20)
  googleReviewUrl      String?
  appointments         Appointment[]
  barbers              Barber[]
  customers            Customer[]
  feedbacks            Feedback[]
  photos               ShopPhoto[]
  services             ShopService[]
  styles               ShopStyle[]
  smsLogs              SmsLog[]
  visits               Visit[]
  walkIns              WalkIn[]
}

model ShopStyle {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  category  String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  imageUrl  String?
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, name])
  @@index([shopId, category])
  @@index([shopId, active])
}

model Barber {
  id               String           @id @default(cuid())
  shopId           String
  name             String
  email            String
  passwordHash     String
  role             String           @default("barber")
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  bio              String?
  photoUrl         String?
  resetToken       String?          @unique
  resetTokenExpiry DateTime?
  acceptsBookings  Boolean          @default(true)
  workingHours     Json?
  isBusy           Boolean          @default(false)
  appointments     Appointment[]
  shop             Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  primaryCustomers Customer[]       @relation("PrimaryBarber")
  feedbackTickets  FeedbackTicket[]
  visits           Visit[]

  @@unique([email, shopId])
  @@index([shopId])
}

model Customer {
  id                     String        @id @default(cuid())
  shopId                 String
  phone                  String
  name                   String?
  smsOptIn               String        @default("not_asked")
  lastVisitAt            DateTime?
  createdAt              DateTime      @default(now())
  accessCode             String?       @unique
  preferredReminderWeeks Int?
  primaryBarberId        String?
  otpCode                String?
  otpExpiry              DateTime?
  appointments           Appointment[]
  checkIns               CheckIn[]
  primaryBarber          Barber?       @relation("PrimaryBarber", fields: [primaryBarberId], references: [id])
  shop                   Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  feedbacks              Feedback[]
  smsLogs                SmsLog[]
  visits                 Visit[]
  walkIns                WalkIn[]
  familyMembers          FamilyMember[]
  familySharings         FamilySharing[] @relation("FamilyOwner")

  @@unique([phone, shopId])
  @@index([shopId, phone])
  @@index([shopId, name])
}

model FamilySharing {
  id              String   @id @default(cuid())
  ownerId         String
  sharedWithPhone String
  createdAt       DateTime @default(now())
  owner           Customer @relation("FamilyOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, sharedWithPhone])
  @@index([sharedWithPhone])
}

model FamilyMember {
  id         String   @id @default(cuid())
  customerId String
  name       String
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  visits     Visit[]
  walkIns    WalkIn[]
  checkIns   CheckIn[]

  @@index([customerId])
}

model Visit {
  id                  String       @id @default(cuid())
  shopId              String
  customerId          String
  barberId            String
  visitedAt           DateTime     @default(now())
  notes               String?
  createdAt           DateTime     @default(now())
  cutDetails          Json?
  recommendation      String?
  cutRating           String?
  stars               Int?
  familyMemberId      String?
  reminderScheduledAt DateTime?
  reminderSentAt      DateTime?
  feedbacks           Feedback[]
  barber              Barber       @relation(fields: [barberId], references: [id])
  customer            Customer     @relation(fields: [customerId], references: [id])
  familyMember        FamilyMember? @relation(fields: [familyMemberId], references: [id])
  shop                Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  photos              VisitPhoto[]

  @@index([customerId])
  @@index([shopId, visitedAt])
}

model VisitPhoto {
  id        String   @id @default(cuid())
  visitId   String
  url       String
  angle     String
  createdAt DateTime @default(now())
  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
}

model SmsLog {
  id         String   @id @default(cuid())
  shopId     String
  customerId String
  message    String
  twilioSid  String?
  status     String   @default("sent")
  sentAt     DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id])
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model ShopPhoto {
  id        String   @id @default(cuid())
  shopId    String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model ShopService {
  id           String        @id @default(cuid())
  shopId       String
  name         String
  duration     Int?
  description  String?
  sortOrder    Int           @default(0)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  price        Decimal?      @db.Decimal(10, 2)
  appointments Appointment[]
  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model Feedback {
  id         String          @id @default(cuid())
  shopId     String
  customerId String
  visitId    String
  rating     String
  stars      Int?
  issue      String?
  sourceType String
  createdAt  DateTime        @default(now())
  customer   Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shop       Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  visit      Visit           @relation(fields: [visitId], references: [id], onDelete: Cascade)
  ticket     FeedbackTicket?

  @@index([shopId, createdAt])
  @@index([customerId, createdAt])
  @@index([visitId])
}

model FeedbackTicket {
  id               String    @id @default(cuid())
  feedbackId       String    @unique
  status           String    @default("unresolved")
  resolution       String?
  assignedBarberId String?
  preferredDate    DateTime?
  notes            String?
  followUpDate     DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  barber           Barber?   @relation(fields: [assignedBarberId], references: [id])
  feedback         Feedback  @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model CheckIn {
  id               String    @id @default(cuid())
  customerId       String
  shopId           String?
  referenceVisitId String?
  styleId          String?
  qrToken          String    @unique @default(uuid())
  expiresAt        DateTime
  familyMemberId   String?
  groupMemberIds   String?
  includeCustomer  Boolean   @default(true)
  scannedAt        DateTime?
  createdAt        DateTime  @default(now())
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  familyMember     FamilyMember? @relation(fields: [familyMemberId], references: [id])
}

model Appointment {
  id             String       @id @default(cuid())
  shopId         String
  customerId     String
  barberId       String?
  serviceId      String?
  scheduledAt    DateTime
  duration       Int
  status         String
  notes          String?
  reminderSentAt DateTime?
  createdAt      DateTime     @default(now())
  barber         Barber?      @relation(fields: [barberId], references: [id])
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service        ShopService? @relation(fields: [serviceId], references: [id])
  shop           Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, scheduledAt])
  @@index([customerId, scheduledAt])
  @@index([barberId, scheduledAt])
}

model WalkIn {
  id             String    @id @default(cuid())
  shopId         String
  customerId     String
  note           String?
  status         String    @default("waiting")
  arrivedAt      DateTime  @default(now())
  startedAt      DateTime?
  doneAt         DateTime?
  createdAt      DateTime  @default(now())
  preferredStyle String?
  familyMemberId String?
  groupId        String?
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  familyMember   FamilyMember? @relation(fields: [familyMemberId], references: [id])
  shop           Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, arrivedAt])
  @@index([shopId, status])
}

model DemoLead {
  id        String   @id @default(cuid())
  name      String
  shopName  String
  phone     String
  email     String
  createdAt DateTime @default(now())
}
