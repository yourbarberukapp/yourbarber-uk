# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string — get from Neon console → Connection string
DATABASE_URL="postgresql://user:password@host:5432/yourbarber"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Twilio SMS ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_PHONE_NUMBER="+441234567890"

# ─── AWS S3 (photo storage) ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_S3_BUCKET="yourbarber-photos"
AWS_REGION="eu-west-2"

# ─── Vercel Cron (reminder scheduler) ────────────────────────────────────────
# Generate with: openssl rand -base64 32
CRON_SECRET="your-cron-secret"

# ─── Resend (password reset emails) ──────────────────────────────────────────
# Get from resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Facebook OAuth ───────────────────────────────────────────────────────────
# Meta Developer Console → App → Facebook Login → Settings
FACEBOOK_CLIENT_ID="your-facebook-app-id"
FACEBOOK_CLIENT_SECRET="your-facebook-app-secret"

# ─── App URL (used in password reset emails) ─────────────────────────────────
APP_URL="http://localhost:3000"
